{
  "name": "uprise-next",
  "version": "1.0.0",
  "private": true,
  "description": "UPRISE - Modernized music community platform",
  "workspaces": [
    "apps/*",
    "apps/workers/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "computer:browser": "pnpm --filter @uprise/openai-computer-use start",
    "computer:browser:install": "pnpm --filter @uprise/openai-computer-use install:chromium",
    "computer:browser:typecheck": "pnpm --filter @uprise/openai-computer-use typecheck",
    "computer:codeexec": "pnpm --filter @uprise/openai-codeexec start",
    "computer:codeexec:install": "pnpm --filter @uprise/openai-codeexec install:chromium",
    "computer:codeexec:typecheck": "pnpm --filter @uprise/openai-codeexec typecheck",
    "computer:desktop": "pnpm --filter @uprise/openai-computer-desktop start",
    "computer:desktop:image:build": "pnpm --filter @uprise/openai-computer-desktop build:image",
    "computer:desktop:typecheck": "pnpm --filter @uprise/openai-computer-desktop typecheck",
    "canon:lint": "node scripts/canon-lint.mjs",
    "docs:lint": "node scripts/docs-lint.mjs && pnpm run canon:lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "typecheck": "turbo run typecheck",
    "infra-policy-check": "tsx scripts/infra-policy-check.ts",
    "infra:check:web": "tsx scripts/infra-policy-check.ts",
    "qa:identity": "pnpm run docs:lint && pnpm run infra-policy-check && pnpm run report:isartist-consumers:strict && pnpm --filter api test:identity && pnpm --filter api typecheck",
    "qa:db": "bash scripts/qa-db.sh",
    "qa:registrar-promoter": "pnpm run docs:lint && pnpm run infra-policy-check && pnpm --filter api test -- registrar.dto.test.ts registrar.controller.test.ts registrar.service.test.ts && pnpm --filter api typecheck && pnpm --filter web typecheck",
    "qa:registrar-artist": "pnpm run docs:lint && pnpm run infra-policy-check && pnpm --filter api test -- registrar.dto.test.ts registrar.controller.test.ts registrar.service.test.ts && pnpm --filter api typecheck && pnpm --filter web typecheck",
    "qa:phase2": "pnpm run docs:lint && pnpm run infra-policy-check && pnpm --filter api test -- auth.invite-registration.service.test.ts registrar.service.test.ts registrar.invite-delivery-worker.test.ts registrar.invite-delivery-trigger.service.test.ts webhook-invite-delivery.provider.test.ts invite-delivery-provider-selector.test.ts && pnpm --filter api typecheck && pnpm --filter web typecheck",
    "qa:phase2:db": "pnpm run qa:db && pnpm --filter api test -- registrar.invite-delivery.integration.test.ts registrar.invite-delivery.replay.integration.test.ts",
    "agent:queue": "node scripts/agent-control.mjs",
    "agent:queue:test": "node scripts/agent-control.test.mjs",
    "agent:bridge:tick": "node scripts/agent-bridge-tick.mjs",
    "agent:bridge:test": "node scripts/agent-bridge-tick.test.mjs",
    "agent:telegram:tick": "node scripts/agent-bridge-telegram.mjs",
    "agent:telegram:test": "node scripts/agent-bridge-telegram.test.mjs",
    "reliant:autopilot": "node scripts/reliant-autopilot.mjs",
    "reliant:seed:backlog": "node scripts/reliant-slice-backlog-seed.mjs",
    "reliant:supervisor": "node scripts/reliant-supervisor.mjs",
    "reliant:supervisor:watch": "node scripts/reliant-supervisor.mjs --watch --interval-ms 5000",
    "reliant:next": "node scripts/reliant-next-action.mjs",
    "reliant:verify:transcript": "node scripts/reliant-verify-transcript.mjs",
    "reliant:runtime:clean": "node scripts/reliant-runtime-clean.mjs",
    "reliant:queue:validate": "node scripts/reliant-slice-queue.mjs validate --queue .reliant/queue/mvp-slices.json",
    "reliant:queue:test": "node scripts/reliant-slice-queue.test.mjs",
    "verify": "pnpm run docs:lint && pnpm run infra-policy-check && pnpm run typecheck",
    "verify:full": "pnpm run verify && pnpm run test && pnpm run build",
    "report:isartist-consumers": "node scripts/is-artist-consumer-report.mjs",
    "report:isartist-consumers:strict": "node scripts/is-artist-consumer-report.mjs --fail-on-unapproved",
    "browser:mcp:launch": "bash scripts/launch-chrome-mcp.sh",
    "browser:mcp:launch:wsl": "bash scripts/launch-chrome-mcp-wsl.sh"
  },
  "devDependencies": {
    "@turbo/gen": "^2.0.0",
    "@types/node": "^20.19.25",
    "prettier": "^3.3.0",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "tsx": "^4.20.6",
    "turbo": "^2.0.0",
    "typescript": "^5.5.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
