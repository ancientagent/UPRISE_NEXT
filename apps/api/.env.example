
# Database
DATABASE_URL="postgresql://uprise:uprise_dev_password@localhost:5432/uprise_dev?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Server
PORT=4000
NODE_ENV=development

# CORS
CORS_ORIGIN="http://localhost:3000"

# PostGIS
# PostGIS extension will be automatically enabled via Prisma migrations

# Location provider
# Use "fake" for local/GPS smoke tests to avoid Google Maps Platform charges.
# Leave unset or use "google" only when intentionally validating Google Places/Geocoding.
UPRISE_LOCATION_PROVIDER="fake"

# Google Places API (for onboarding autocomplete/reverse geocoding when UPRISE_LOCATION_PROVIDER is not fake)
GOOGLE_PLACES_API_KEY="your-google-places-api-key"
