
// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis]
}

model User {
  id          String    @id @default(uuid())
  email       String    @unique
  username    String    @unique
  displayName String
  password    String
  bio         String?
  avatar      String?
  coverImage  String?
  latitude    Float?
  longitude   Float?
  city        String?
  country     String?
  homeSceneCity       String?
  homeSceneState      String?
  homeSceneCommunity  String?
  homeSceneTag        String?
  tunedSceneId        String?
  tunedSceneUpdatedAt DateTime?
  collectionDisplayEnabled Boolean @default(false)
  gpsVerified         Boolean   @default(false)
  isVerified  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tracks             Track[]
  communities        CommunityMember[]
  createdCommunities Community[]
  events             Event[]
  tags               UserTag[]
  signals            Signal[]
  signalActions      SignalAction[]
  follows            Follow[]
  collections        Collection[]
  trackEngagements   TrackEngagement[]
  trackVotes         TrackVote[]
  createdArtistBands ArtistBand[]
  artistBandMembers  ArtistBandMember[]
  registrarEntries   RegistrarEntry[]
  registrarArtistMemberships RegistrarArtistMember[] @relation("RegistrarExistingUser")
  registrarClaimedMemberships RegistrarArtistMember[] @relation("RegistrarClaimedUser")
  capabilityGrants  UserCapabilityGrant[]
  capabilityAuditTargetEvents CapabilityGrantAuditLog[] @relation("CapabilityAuditTargetUser")
  capabilityAuditActorEvents  CapabilityGrantAuditLog[] @relation("CapabilityAuditActorUser")

  @@map("users")
}

model ArtistBand {
  id               String   @id @default(uuid())
  name             String
  slug             String   @unique
  entityType       String   @default("artist") // artist, band
  registrarEntryRef String?
  homeSceneId      String?
  createdById      String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  createdBy User      @relation(fields: [createdById], references: [id], onDelete: Restrict)
  homeScene Community? @relation(fields: [homeSceneId], references: [id], onDelete: SetNull)
  members   ArtistBandMember[]
  registrarEntries RegistrarEntry[]
  tracks    Track[]
  events    Event[]

  @@index([homeSceneId])
  @@index([createdById])
  @@map("artist_bands")
}

model ArtistBandMember {
  id           String   @id @default(uuid())
  artistBandId String
  userId       String
  role         String   @default("manager") // owner, manager, collaborator
  createdAt    DateTime @default(now())

  artistBand ArtistBand @relation(fields: [artistBandId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([artistBandId, userId])
  @@index([userId])
  @@map("artist_band_members")
}

model Community {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String
  coverImage  String?
  avatar      String?
  isPrivate   Boolean  @default(false)
  memberCount Int      @default(0)
  createdById String
  city        String?
  state       String?
  musicCommunity String?
  tier        String   @default("city") // city, state, national
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // PostGIS geography column for geofencing
  geofence Unsupported("geography(Point, 4326)")?
  radius   Float? // radius in meters

  createdBy User              @relation(fields: [createdById], references: [id])
  members   CommunityMember[]
  tracks    Track[]
  events    Event[]
  sectTags  SectTag[]
  signals   Signal[]
  rotationEntries RotationEntry[]
  trackVotes TrackVote[]
  artistBands ArtistBand[]
  registrarEntries RegistrarEntry[]

  @@map("communities")
}

model RegistrarEntry {
  id           String   @id @default(uuid())
  type         String
  status       String   @default("submitted")
  sceneId      String
  createdById  String
  artistBandId String?
  payload      Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  scene      Community  @relation(fields: [sceneId], references: [id], onDelete: Restrict)
  createdBy  User       @relation(fields: [createdById], references: [id], onDelete: Restrict)
  artistBand ArtistBand? @relation(fields: [artistBandId], references: [id], onDelete: SetNull)
  artistMembers RegistrarArtistMember[]
  codes      RegistrarCode[]
  capabilityGrants UserCapabilityGrant[]
  capabilityAuditEvents CapabilityGrantAuditLog[]

  @@index([sceneId, type, status])
  @@index([createdById, createdAt])
  @@index([artistBandId])
  @@map("registrar_entries")
}

model RegistrarCode {
  id              String   @id @default(uuid())
  registrarEntryId String
  capability      String
  codeHash        String   @unique
  issuerType      String   @default("system")
  status          String   @default("issued")
  expiresAt       DateTime?
  redeemedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  registrarEntry RegistrarEntry @relation(fields: [registrarEntryId], references: [id], onDelete: Cascade)
  capabilityGrants UserCapabilityGrant[]
  capabilityAuditEvents CapabilityGrantAuditLog[]

  @@index([registrarEntryId, status])
  @@index([capability, status])
  @@map("registrar_codes")
}

model UserCapabilityGrant {
  id                    String   @id @default(uuid())
  userId                String
  capability            String
  status                String   @default("active") // active, revoked
  sourceRegistrarEntryId String?
  sourceRegistrarCodeId String?
  grantedAt             DateTime @default(now())
  revokedAt             DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user                User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceRegistrarEntry RegistrarEntry? @relation(fields: [sourceRegistrarEntryId], references: [id], onDelete: SetNull)
  sourceRegistrarCode  RegistrarCode?  @relation(fields: [sourceRegistrarCodeId], references: [id], onDelete: SetNull)

  @@unique([userId, capability])
  @@index([capability, status])
  @@index([sourceRegistrarEntryId])
  @@index([sourceRegistrarCodeId])
  @@map("user_capability_grants")
}

model CapabilityGrantAuditLog {
  id              String   @id @default(uuid())
  capability      String
  action          String
  actorType       String   @default("system")
  targetUserId    String?
  actorUserId     String?
  registrarEntryId String?
  registrarCodeId String?
  metadata        Json?
  createdAt       DateTime @default(now())

  targetUser     User?          @relation("CapabilityAuditTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)
  actorUser      User?          @relation("CapabilityAuditActorUser", fields: [actorUserId], references: [id], onDelete: SetNull)
  registrarEntry RegistrarEntry? @relation(fields: [registrarEntryId], references: [id], onDelete: SetNull)
  registrarCode  RegistrarCode?  @relation(fields: [registrarCodeId], references: [id], onDelete: SetNull)

  @@index([capability, action, createdAt])
  @@index([registrarEntryId, createdAt])
  @@index([targetUserId, createdAt])
  @@map("capability_grant_audit_logs")
}

model RegistrarArtistMember {
  id              String   @id @default(uuid())
  registrarEntryId String
  name            String
  email           String
  city            String
  instrument      String
  existingUserId  String?
  claimedUserId   String?
  inviteStatus    String   @default("pending_email") // pending_email, existing_user, sent, failed
  inviteToken     String?
  inviteTokenExpiresAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  registrarEntry RegistrarEntry @relation(fields: [registrarEntryId], references: [id], onDelete: Cascade)
  existingUser   User?          @relation("RegistrarExistingUser", fields: [existingUserId], references: [id], onDelete: SetNull)
  claimedUser    User?          @relation("RegistrarClaimedUser", fields: [claimedUserId], references: [id], onDelete: SetNull)
  deliveries     RegistrarInviteDelivery[]

  @@unique([registrarEntryId, email])
  @@unique([inviteToken])
  @@index([email])
  @@index([existingUserId])
  @@index([claimedUserId])
  @@map("registrar_artist_members")
}

model RegistrarInviteDelivery {
  id                     String   @id @default(uuid())
  registrarArtistMemberId String   @unique
  email                  String
  status                 String   @default("queued") // queued, sent, failed
  payload                Json
  dispatchedAt           DateTime?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  registrarArtistMember RegistrarArtistMember @relation(fields: [registrarArtistMemberId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@map("registrar_invite_deliveries")
}

model SectTag {
  id                String   @id @default(uuid())
  name              String
  status            String   @default("active") // active, incubating
  parentCommunityId String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  parentCommunity Community @relation(fields: [parentCommunityId], references: [id])
  users           UserTag[]

  @@unique([name, parentCommunityId])
  @@map("sect_tags")
}

model UserTag {
  id        String   @id @default(uuid())
  userId    String
  sectTagId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  sectTag SectTag @relation(fields: [sectTagId], references: [id])

  @@unique([userId, sectTagId])
  @@map("user_tags")
}

model CommunityMember {
  id          String   @id @default(uuid())
  userId      String
  communityId String
  role        String   @default("member") // member, moderator, admin
  joinedAt    DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id])
  community Community @relation(fields: [communityId], references: [id])

  @@unique([userId, communityId])
  @@map("community_members")
}

model Track {
  id            String   @id @default(uuid())
  title         String
  artist        String
  artistBandId  String?
  album         String?
  duration      Float // in seconds
  fileUrl       String
  coverArt      String?
  waveformData  Json?
  uploadedById  String
  communityId   String?
  playCount     Int      @default(0)
  likeCount     Int      @default(0)
  status        String   @default("processing") // processing, ready, failed
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  uploadedBy    User             @relation(fields: [uploadedById], references: [id])
  artistBand    ArtistBand?      @relation(fields: [artistBandId], references: [id], onDelete: SetNull)
  community     Community?       @relation(fields: [communityId], references: [id])
  engagements   TrackEngagement[]
  rotationEntries RotationEntry[]
  trackVotes    TrackVote[]

  @@index([artistBandId])
  @@map("tracks")
}

// Engagement events for Fair Play scoring (Canon: 3/2/1/0 model)
model TrackEngagement {
  id          String   @id @default(uuid())
  userId      String
  trackId     String
  type        String   // full, majority, partial, skip (validated in app layer)
  score       Int      // 3, 2, 1, 0 per Canon - derived from type
  sessionId   String   // playback session identifier for spam prevention
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  track       Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([userId, trackId, sessionId])
  @@index([trackId, createdAt])
  @@map("track_engagements")
}

enum RotationPool {
  NEW_RELEASES
  MAIN_ROTATION
}

model RotationEntry {
  id              String       @id @default(uuid())
  trackId         String
  sceneId         String
  pool            RotationPool
  enteredPoolAt   DateTime
  lastPlayedAt    DateTime?
  recurrenceScore Float        @default(0)
  graduatedAt     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  track           Track        @relation(fields: [trackId], references: [id], onDelete: Cascade)
  scene           Community    @relation(fields: [sceneId], references: [id], onDelete: Cascade)

  @@unique([trackId, sceneId])
  @@index([sceneId, pool, recurrenceScore])
  @@index([pool, enteredPoolAt])
  @@map("rotation_entries")
}

model TrackVote {
  id                String    @id @default(uuid())
  userId            String
  trackId           String
  sceneId           String
  tier              String
  playbackSessionId String
  createdAt         DateTime  @default(now())

  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  track             Track     @relation(fields: [trackId], references: [id], onDelete: Cascade)
  scene             Community @relation(fields: [sceneId], references: [id], onDelete: Cascade)

  @@unique([userId, trackId, sceneId, tier])
  @@index([sceneId, tier, createdAt])
  @@map("track_votes")
}

model Signal {
  id          String   @id @default(uuid())
  type        String
  metadata    Json?
  communityId String?
  createdById String?
  createdAt   DateTime @default(now())

  community Community? @relation(fields: [communityId], references: [id])
  createdBy User?      @relation(fields: [createdById], references: [id])
  actions   SignalAction[]
  collectionItems CollectionItem[]

  @@map("signals")
}

model SignalAction {
  id        String   @id @default(uuid())
  type      String
  userId    String
  signalId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  signal Signal @relation(fields: [signalId], references: [id])

  @@unique([userId, signalId, type])
  @@map("signal_actions")
}

model Follow {
  id          String   @id @default(uuid())
  followerId  String
  entityType  String
  entityId    String
  createdAt   DateTime @default(now())

  follower User @relation(fields: [followerId], references: [id])

  @@unique([followerId, entityType, entityId])
  @@map("follows")
}

model Collection {
  id        String   @id @default(uuid())
  name      String
  userId    String
  createdAt DateTime @default(now())

  user  User @relation(fields: [userId], references: [id])
  items CollectionItem[]

  @@unique([userId, name])
  @@map("collections")
}

model CollectionItem {
  id           String   @id @default(uuid())
  collectionId String
  signalId     String
  createdAt    DateTime @default(now())

  collection Collection @relation(fields: [collectionId], references: [id])
  signal     Signal     @relation(fields: [signalId], references: [id])

  @@unique([collectionId, signalId])
  @@map("collection_items")
}

model Event {
  id            String   @id @default(uuid())
  title         String
  description   String
  coverImage    String?
  startDate     DateTime
  endDate       DateTime
  locationName  String
  address       String
  latitude      Float
  longitude     Float
  communityId   String
  createdById   String
  artistBandId  String?
  attendeeCount Int      @default(0)
  maxAttendees  Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  community Community @relation(fields: [communityId], references: [id])
  createdBy User      @relation(fields: [createdById], references: [id])
  artistBand ArtistBand? @relation(fields: [artistBandId], references: [id], onDelete: SetNull)

  @@index([artistBandId])
  @@map("events")
}

model FairPlayConfig {
  id                               String   @id @default(uuid())
  scope                            String   @unique @default("global")
  recurrenceReorderHours           Int?
  recurrenceRollingWindowDays      Int?
  bandPersistDays                  Int?
  newWindowBandLowMaxActive        Int?
  newWindowBandLowDays             Int?
  newWindowBandMidMinActive        Int?
  newWindowBandMidMaxActive        Int?
  newWindowBandMidDays             Int?
  newWindowBandHighMinActive       Int?
  newWindowBandHighDays            Int?
  graduationMinAgeDays             Int?
  graduationExecutionCadenceDays   Int?
  graduationCapPerRun              Int?
  propagationMinUniqueListeners    Int?
  propagationRateThreshold         Float?
  propagationConfidenceGate        Float?
  createdAt                        DateTime @default(now())
  updatedAt                        DateTime @updatedAt

  @@map("fair_play_config")
}
